<scene>
    <integrator type="direct"/>

    <sampler type="stratified">
        <int name="x_pixel_samples" value="2"/>
        <int name="y_pixel_samples" value="2"/>
        <bool name="jitter" value="true"/>
    </sampler>

    <camera type="orthographic">
        <point3 name="eye" value="10.0, 10.0, 10.0"/>
        <point3 name="target" value="0.0, 0.0, 0.0"/>
        <vector3 name="up" value="0.0, 1.0, 0.0"/>

        <float name="extent" value="2"/>

        <film type="film" name="film">
            <point2 name="resolution" value="512, 512"/>
            <string name="filename" value="output/its.png"/>
            <float name="scale" value="1.0"/>
            <float name="diagonal" value="35.0"/>

            <filter type="triangle" name="filter">
                <vector2 name="radius" value="1.0, 1.0"/>
            </filter>
        </film>
    </camera>

    <shape type="sphere">
        <float name="radius" value="1.0"/>

        <scale value="0.3, 0.3, 0.3"/>
    </shape>

    <shape type="mesh">
        <string name="filename" value="monkey.obj"/>
        
        <scale value="0.5, 0.5, 0.5"/>
        <rotate value="0, 1, 0, 30"/>
        <translate value="2, 0, 0"/>
    </shape>

    <shape type="mesh">
        <string name="filename" value="monkey.obj"/>
        
        <scale value="0.7, 0.7, 0.7"/>
        <rotate value="1, 1, 1, 45"/>
        <translate value="-2, 0, 0"/>
    </shape>

    <light type="point"/>
</scene>
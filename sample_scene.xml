<scene>
    <integrator type="direct"/>

    <sampler type="stratified">
        <int name="x_pixel_samples" value="4"/>
        <int name="y_pixel_samples" value="4"/>
        <bool name="jitter" value="true"/>
    </sampler>

    <camera type="orthographic">
        <point3 name="eye" value="10.0, 10.0, 10.0"/>
        <point3 name="target" value="0.0, 0.0, 0.0"/>
        <vector3 name="up" value="0.0, 1.0, 0.0"/>

        <float name="extent" value="2"/>

        <film type="film" name="film">
            <point2 name="resolution" value="512, 512"/>
            <string name="filename" value="z_output/direct.png"/>
            <float name="scale" value="1.0"/>
            <float name="diagonal" value="35.0"/>

            <filter type="triangle" name="filter">
                <vector2 name="radius" value="1.0, 1.0"/>
            </filter>
        </film>
    </camera>

    <primitive type="geometric">
        <shape type="mesh">
            <!-- <float name="radius" value="0.3"/> -->
            <string name="filename" value="z_input/plane.obj"/>
            
            <!-- <scale value="0.3, 0.3, 0.3"/> -->
            <translate value="0.0, -1.0, 0"/>
        </shape>
        
        <light type="diffuse">
            <vector3 name="l_emit" value="2.0, 2.0, 2.0"/>
        </light>

        <material type="matte">
            <vector3 name="color" value="1.0, 0.0, 1.0"/>
        </material>
    </primitive>
    
    <primitive type="geometric">
        <shape type="mesh">
            <string name="filename" value="z_input/monkey.obj"/>
            
            <scale value="0.5, 0.5, 0.5"/>
            <rotate value="0, 1, 0, 30"/>
            <translate value="0.0, 2.0, 0"/>
        </shape>

        <material type="matte">
            <vector3 name="color" value="0.1, 1.0, 0.0"/>
        </material>
    </primitive>

    <primitive type="geometric">
        <shape type="mesh">
            <string name="filename" value="z_input/monkey.obj"/>
            
            <scale value="0.3, 0.3, 0.3"/>
            <rotate value="1, 1, 1, 45"/>
            <translate value="-2, 0, 0"/>
        </shape>

        
        <material type="matte">
            <vector3 name="color" value="0.1, 1.0, 1.0"/>
        </material>
    </primitive>
    
    <light type="point">
        <vector3 name="i" value="20, 20, 20"/>
        <translate value="2.0, 2.0, 2.0"/>
    </light>
</scene>
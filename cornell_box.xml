<scene>
    <integrator type="direct"/>

    <sampler type="stratified">
        <int name="x_pixel_samples" value="11"/>
        <int name="y_pixel_samples" value="11"/>
        <bool name="jitter" value="true"/>
    </sampler>

    <camera type="perspective">
        <point3 name="eye" value="2.3, 1.0, 0.0"/>
        <point3 name="target" value="0.0, 1.0, 0.0"/>
        <vector3 name="up" value="0.0, 1.0, 0.0"/>

        <float name="extent" value="2"/>

        <film type="film" name="film">
            <point2 name="resolution" value="512, 512"/>
            <string name="filename" value="z_output/direct.png"/>
            <float name="scale" value="1.0"/>
            <float name="diagonal" value="35.0"/>

            <filter type="triangle" name="filter">
                <vector2 name="radius" value="1.0, 1.0"/>
            </filter>
        </film>
    </camera>

    <primitive type="geometric">
        <shape type="mesh">
            <string name="filename" value="z_input/plane.obj"/>
            
        </shape>

        <material type="matte">
            <vector3 name="color" value="0.4, 0.4, 0.4"/>
        </material>
    </primitive>

    <primitive type="geometric">
        <shape type="mesh">
            <string name="filename" value="z_input/plane.obj"/>
            
            <rotate value="1.0, 0.0, 0.0, 90"/>
            <translate value="0.0, 1.0, 1.0"/>
        </shape>
        
        <material type="matte">
            <vector3 name="color" value="0.0, 0.5, 0.0"/>
        </material>
    </primitive>

    <primitive type="geometric">
        <shape type="mesh">
            <string name="filename" value="z_input/plane.obj"/>
            
            <rotate value="1.0, 0.0, 0.0, -90"/>
            <translate value="0.0, 1.0, -1.0"/>
        </shape>
        
        <material type="matte">
            <vector3 name="color" value="0.5, 0.0, 0.0"/>
        </material>
    </primitive>

    <primitive type="geometric">
        <shape type="mesh">
            <string name="filename" value="z_input/plane.obj"/>
            
            <rotate value="1.0, 0.0, 0.0, 180"/>
            <translate value="0.0, 2.0, 0.0"/>
        </shape>
        
        <material type="matte">
            <vector3 name="color" value="0.4, 0.4, 0.4"/>
        </material>
    </primitive>

    <primitive type="geometric">
        <shape type="mesh">
            <string name="filename" value="z_input/plane.obj"/>
            
            <rotate value="0.0, 0.0, 1.0, 90"/>
            <translate value="-1.0, 1.0, 0.0"/>
        </shape>
        
        <material type="matte">
            <vector3 name="color" value="0.4, 0.4, 0.4"/>
        </material>
    </primitive>

    <primitive type="geometric">
        <shape type="mesh">
            <string name="filename" value="z_input/cube.obj"/>
            
            <scale value="0.3, 0.3, 0.3"/>
            <rotate value="0.0, 1.0, 0.0, 20"/>
            <translate value="0.2, 0.0, 0.2"/>
        </shape>
        
        <material type="matte">
            <vector3 name="color" value="0.5, 0.5, 0.5"/>
        </material>
    </primitive>

    <primitive type="geometric">
        <shape type="mesh">
            <string name="filename" value="z_input/plane.obj"/>
            
            <scale value="0.105, 1.0, 0.13"/>
            <rotate value="0.0, 0.0, 1.0, 180"/>
            <translate value="0.0, 1.99, 0.0"/>
        </shape>
        
        <material type="matte">
            <vector3 name="color" value="0.4, 0.4, 0.4"/>
        </material>

        <light type="diffuse">
            <vector3 name="l_emit" value="100.0, 100.0, 100.0"/>
        </light>
    </primitive>
    
    <!-- <light type="point">
        <vector3 name="i" value="1, 1, 1"/>
        <translate value="0.0, 1.99, 0.0"/>
    </light> -->
</scene>
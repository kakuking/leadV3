<scene>
    <!-- Integrator -->
    <integrator type="volume"/>

    <!-- Sampler -->
    <sampler type="halton">
        <int name="samples_per_pixel" value="64"/>
        <point2 name="sample_bound_min" value="0, 0"/>
        <point2 name="sample_bound_max" value="512, 512"/>
    </sampler>

    <!-- Camera -->
    <camera type="perspective">
        <point3 name="eye" value="2.3, 1.0, 0.0"/>
        <point3 name="target" value="0.0, 1.0, 0.0"/>
        <vector3 name="up" value="0.0, 1.0, 0.0"/>

        <float name="extent" value="2"/>

        <film type="film" name="film">
            <point2 name="resolution" value="512, 512"/>
            <string name="filename" value="z_output/volume.png"/>
            <float name="scale" value="1.0"/>
            <float name="diagonal" value="35.0"/>

            <filter type="triangle" name="filter">
                <vector2 name="radius" value="1.0, 1.0"/>
            </filter>
        </film>
    </camera>

    <!-- Bottom Plane -->
    <primitive type="geometric">
        <shape type="mesh">
            <string name="filename" value="z_input/plane.obj"/>
            
        </shape>

        <material type="matte">
            <texture name="kd" type="checkerboard">
                <mapping type="uv">
                    <float name="su" value="10"/>
                    <float name="sv" value="10"/>
                </mapping>
                <texture name="tex1" type="constant">
                    <vector3 name="value" value="0.4, 0.4, 0.4"/>
                </texture>
                <texture name="tex2" type="constant">
                    <vector3 name="value" value="0.0, 0.0, 0.0"/>
                </texture>
            </texture>
            <texture name="sigma" type="constant">
                <vector3 name="value" value="0.0, 0.0, 0.0"/>
            </texture>
        </material>
    </primitive>

    <!-- Right Plane -->
    <primitive type="geometric">
        <shape type="mesh">
            <string name="filename" value="z_input/plane.obj"/>
            
            <rotate value="1.0, 0.0, 0.0, 90"/>
            <translate value="0.0, 1.0, 1.0"/>
        </shape>
        
        <material type="matte">
            <texture name="kd" type="constant">
                <vector3 name="value" value="0.0, 0.5, 0.0"/>
            </texture>
            <texture name="sigma" type="constant">
                <vector3 name="value" value="0.0, 0.0, 0.0"/>
            </texture>
        </material>
    </primitive>

    <!-- Left Plane -->
    <primitive type="geometric">
        <shape type="mesh">
            <string name="filename" value="z_input/plane.obj"/>
            
            <rotate value="1.0, 0.0, 0.0, -90"/>
            <translate value="0.0, 1.0, -1.0"/>
        </shape>
        
        <material type="matte">
            <texture name="kd" type="constant">
                <vector3 name="value" value="0.5, 0.0, 0.0"/>
            </texture>
            <texture name="sigma" type="constant">
                <vector3 name="value" value="0.0, 0.0, 0.0"/>
            </texture>
        </material>
    </primitive>

    <!-- Top Plane -->
    <primitive type="geometric">
        <shape type="mesh">
            <string name="filename" value="z_input/plane.obj"/>
            
            <rotate value="1.0, 0.0, 0.0, 180"/>
            <translate value="0.0, 2.0, 0.0"/>
        </shape>
        
        <material type="matte">
            <texture name="kd" type="constant">
                <vector3 name="value" value="0.4, 0.4, 0.4"/>
            </texture>
            <texture name="sigma" type="constant">
                <vector3 name="value" value="0.0, 0.0, 0.0"/>
            </texture>
        </material>
    </primitive>

    <!-- Back Plane -->
    <primitive type="geometric">
        <shape type="mesh">
            <string name="filename" value="z_input/plane.obj"/>
            
            <rotate value="0.0, 0.0, 1.0, 90"/>
            <translate value="-1.0, 1.0, 0.0"/>
        </shape>
        
        <material type="matte">
            <texture name="kd" type="constant">
                <vector3 name="value" value="0.4, 0.4, 0.4"/>
            </texture>
            <texture name="sigma" type="constant">
                <vector3 name="value" value="0.0, 0.0, 0.0"/>
            </texture>
        </material>
    </primitive>
    
    <!-- Top Light -->
    <primitive type="geometric">
        <shape type="mesh">
            <string name="filename" value="z_input/plane.obj"/>
            
            <scale value="0.5, 1.0, 0.5"/>
            <rotate value="0.0, 0.0, 1.0, 180"/>
            <translate value="0.0, 1.999, 0.0"/>
        </shape>
        
        <material type="matte">
            <texture name="kd" type="constant">
                <vector3 name="value" value="0.4, 0.4, 0.4"/>
            </texture>
            <texture name="sigma" type="constant">
                <vector3 name="value" value="0.0, 0.0, 0.0"/>
            </texture>
        </material>
        
        <light type="diffuse">
            <vector3 name="l_emit" value="4.0, 4.0, 4.0"/>
        </light>
    </primitive>
    
    <!-- Cube -->
    <primitive type="geometric">
        <shape type="mesh">
            <string name="filename" value="z_input/cube.obj"/>
            
            <scale value="0.3, 0.3, 0.3"/>
            <rotate value="0.0, 1.0, 0.0, 20"/>
            <translate value="0.4, 0.0, 0.4"/>
        </shape>
        
        <material type="matte">
            <texture name="kd" type="constant">
                <vector3 name="value" value="0.5, 0.5, 0.5"/>
            </texture>
            <texture name="sigma" type="constant">
                <vector3 name="value" value="0.0, 0.0, 0.0"/>
            </texture>
        </material>
    </primitive>
    
    <!-- Monkey Smoke -->
    <primitive type="geometric">
        <shape type="mesh">
            <!-- The mesh works as a smoke bounding box -->
            <string name="filename" value="z_input/cube.obj"/>
            
            <rotate value="1.0, 0.0, 0.0, -90"/>
            <scale value="1.8, 1.8, 1.8"/>
            <rotate value="0.0, 1.0, 0.0, 90.0"/>
            <translate value="0.0, 0.0, 0.5"/>
        </shape>
        <medium name="inside" type="heterogeneous">
            <string name="filename" value="z_input/monkey.vdb"/>
            <vector3 name="sigma_s" value="0.0, 0.0, 2.0"/>
            <vector3 name="sigma_a" value="5.0, 0.0, 0.0"/>
            <float name="g" value="0.0"/>
            
                <!-- Absolute heterogeneous medium transform -->
                <rotate value="1.0, 0.0, 0.0, -90"/>
                <scale value="1.7, 1.7, 1.7"/>
                <rotate value="0.0, 1.0, 0.0, 90.0"/>
                <translate value="0.0, 0.0, 0.5"/>
            </medium>
    </primitive>
</scene>
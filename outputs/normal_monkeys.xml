<scene>
    <!-- integrator -->
    <integrator type="normal"/>

    <!-- sampler -->
    <sampler type="stratified">
        <vector2 name="samples" value="8, 8"/>
    </sampler>

    <!-- camera -->
    <camera type="orthographic">
        <point3 name="eye" value="10.0, 10.0, 10.0"/>
        <point3 name="target" value="0.0, 1.0, 0.0"/>
        <vector3 name="up" value="0.0, 1.0, 0.0"/>

        <float name="extent" value="2"/>

        <film type="film" name="film">
            <point2 name="resolution" value="1024, 1024"/>
            <string name="filename" value="outputs/normal_monkeys.png"/>
            <float name="scale" value="1.0"/>
            <float name="diagonal" value="35.0"/>

            <filter type="triangle" name="filter">
                <vector2 name="radius" value="1.0, 1.0"/>
            </filter>
        </film>
    </camera>

    <!-- sphere -->
    <primitive type="geometric">
        <shape type="sphere">
            <float name="radius" value="0.3"/>
            
            <scale value="5.0, 5.0, 5.0"/>
            <translate value="0.0, -1.0, 0"/>
        </shape>

        <material type="matte">
            <texture name="kd" type="constant">
                <vector3 name="value" value="0.4, 0.4, 0.4"/>
            </texture>
            <texture name="sigma" type="constant">
                <vector3 name="value" value="0.0, 0.0, 0.0"/>
            </texture>
        </material>
    </primitive>
    
    <!-- monkey 1 -->
    <primitive type="geometric">
        <shape type="mesh">
            <string name="filename" value="./outputs/resources/monkey.obj"/>
            
            <scale value="0.5, 0.5, 0.5"/>
            <rotate value="0, 1, 0, 30"/>
            <translate value="0.0, 2.0, 0"/>
        </shape>

        <material type="matte">
            <texture name="kd" type="constant">
                <vector3 name="value" value="0.4, 0.4, 0.4"/>
            </texture>
            <texture name="sigma" type="constant">
                <vector3 name="value" value="0.0, 0.0, 0.0"/>
            </texture>
        </material>
    </primitive>

    <!-- monkey 2 -->
    <primitive type="geometric">
        <shape type="mesh">
            <string name="filename" value="./outputs/resources/monkey.obj"/>
            
            <scale value="0.3, 0.3, 0.3"/>
            <rotate value="1, 1, 1, 45"/>
            <translate value="-2, 0, 0"/>
        </shape>

        
        <material type="matte">
            <texture name="kd" type="constant">
                <vector3 name="value" value="0.4, 0.4, 0.4"/>
            </texture>
            <texture name="sigma" type="constant">
                <vector3 name="value" value="0.0, 0.0, 0.0"/>
            </texture>
        </material>
    </primitive>
    
    <!-- point light -->
    <light type="point">
        <vector3 name="i" value="20, 20, 20"/>
        <translate value="2.0, 2.0, 2.0"/>
    </light>
</scene>